# ============================================================
# PetroChat-Agent 环境变量模板
# 使用方法：复制本文件为 .env，并填入真实凭证
#   Windows PowerShell:  Copy-Item .env.example .env
#   Linux / Mac:         cp .env.example .env
# ⚠️ .env 已加入 .gitignore，绝不能提交到 Git
# ============================================================

# ---------- 应用配置 ----------
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# ---------- 记忆窗口（Phase 6 短期+长期记忆）----------
SHORT_TERM_TURNS=6                # 短期对话历史保留多少轮
LONG_TERM_MEMORY_LIMIT=5          # 长期记忆每次召回多少条

# ---------- Auth / RBAC ----------
# Dev can use any long random string; production must override it.
AUTH_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_TOKEN_EXPIRE_MINUTES=480
# Compatible with the current plaintext user.password column in dev.
# Set false in production after migrating to pbkdf2_sha256$... hashes.
AUTH_ALLOW_PLAINTEXT_PASSWORDS=true

# ---------- Retention cleanup ----------
RETENTION_CONVERSATION_DAYS=180
RETENTION_CONVERSATION_RECOVERY_DAYS=30
RETENTION_TOOL_LOG_DAYS=365
RETENTION_RETRIEVAL_CONTEXT_DAYS=90
RETENTION_AUDIT_LOG_DAYS=1095
RETENTION_TEMP_FILE_DAYS=30

# ---------- Evaluation quality gate ----------
EVAL_GATE_SUCCESS_RATE=0.95
EVAL_GATE_SQL_TEMPLATE_VALID_RATE=0.95
EVAL_GATE_SQL_VALIDATION_RATE=0.95
EVAL_GATE_SQL_CONTRACT_ACCURACY=0.85
EVAL_GATE_RAG_RECALL_AT_5=0.85
EVAL_GATE_RAG_MRR=0.65
EVAL_GATE_RAG_FAITHFULNESS_PROXY=0.85
EVAL_GATE_MEMORY_HIT_RATE=0.80
EVAL_GATE_MEMORY_IGNORE_VIOLATION_RATE=0.0
EVAL_GATE_MAX_AVG_LATENCY_MS=15000
# ---------- 评估产物路径 ----------
EVAL_RESULTS_PATH=data/eval_results
EVAL_PREDICTIONS_PATH=data/eval_results/predictions.jsonl

# ---------- DeepSeek（用于 Chat 生成 / 后续评分）----------
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ---------- 阿里云百炼（用于 Embedding 向量化）----------
# 申请地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=10   # 百炼实测上限，切 OpenAI 可调大

# ---------- Chroma 向量库（HTTP 服务，由 docker-compose 启动）----------
# 启动方式：在项目根目录执行 `docker compose up -d chroma`
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=petrochat_specs

# ---------- LangSmith 链路追踪（可选但推荐）----------
# 申请地址: https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_key
LANGSMITH_PROJECT=petrochat-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---------- MCP（第三阶段）----------
# 关：agent 用 in-process 工具 (默认，phase 2 行为)
# 开：agent 通过 MCP 协议调远端工具进程 (phase 3)
MCP_ENABLED=true
MCP_TRANSPORT=stdio                              # stdio / streamable_http
MCP_SERVER_COMMAND=python                        # stdio 模式：父进程拉起子进程的命令
MCP_SERVER_ARGS=-m petrochat.app.mcp.server      # stdio 模式参数
MCP_SERVER_URL=http://localhost:8765/mcp         # streamable_http 模式 URL

# ---------- MySQL 数据库（第四阶段 NL2SQL）----------
# 强烈建议：用只读账号（GRANT SELECT ONLY），不要给生产管理员密码
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=timing_task
MYSQL_USER=timing_reader
MYSQL_PASSWORD=1234
# SQL 安全护栏（NL2SQL 自动注入）
SQL_DEFAULT_LIMIT=1000        # 没显式 LIMIT 的查询自动追加
SQL_TIMEOUT_SECONDS=10        # 单 SQL 执行超时
# 只把 prompt 给 LLM 的表白名单（逗号分隔；留空 = 全库所有表）
MYSQL_TABLES_WHITELIST=affair,affair_task
# 枚举值采样阈值：distinct 数 <= 此值的列把实际取值喂给 LLM
MYSQL_ENUM_SAMPLE_THRESHOLD=30

# ---------- MySQL 应用专属账号（写 agent_* 表用，与只读账号物理分离）----------
# 留空则回退到 MYSQL_USER（开发期方便，但生产应配独立账号）
# 需要先在 MySQL 里执行：
#   CREATE USER 'petrochat_app'@'%' IDENTIFIED BY '<强密码>';
#   GRANT SELECT,INSERT,UPDATE,DELETE ON timing_task.agent_* TO 'petrochat_app'@'%';
#   FLUSH PRIVILEGES;
MYSQL_APP_USER=
MYSQL_APP_PASSWORD=

# ---------- Docker demo overrides ----------
# docker-compose.yml automatically uses service names inside containers:
#   CHROMA_HOST=chroma
#   CHROMA_PORT=8000
#   MYSQL_HOST=mysql
#   MYSQL_PORT=3306
# Host ports can be changed without editing compose:
# ============================================================
# 以下变量仅 docker-compose 使用（不会被 Settings 加载）
# ============================================================
MYSQL_PUBLISHED_PORT=3307
CHROMA_PUBLISHED_PORT=8001
API_PUBLISHED_PORT=8000
FRONTEND_PUBLISHED_PORT=5173
PETROCHAT_MYSQL_ROOT_PASSWORD=petrochat_root_demo

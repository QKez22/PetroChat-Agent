.uv-cache/

# ============== IDE ==============
.idea/
.vscode/
*.swp
*.swo
*~

# ============== OS ==============
.DS_Store
Thumbs.db
desktop.ini

# ============== 项目专属 ==============
# 环境变量（含 API Key，绝不提交）
.env
.env.local
.env.*.local

# 向量库本地数据（Chroma 持久化目录）
chroma_db/
vector_store/
*.chroma/

# 原始 / 中间数据（保留目录结构，不提交大文件）
data/raw/*
!data/raw/.gitkeep
data/processed/
data/interim/

# 日志
*.log
logs/

# Frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# LangGraph checkpoint（如果用 SQLite 持久化）
checkpoints/
*.sqlite
*.sqlite3

# 模型缓存（如果本地跑 embedding）
.cache/
models/

# 临时文件
tmp/
temp/
